---
import '@fontsource-variable/nunito';
import '../styles/global.css';
import { site } from '../data/site.js';

const { title, description } = Astro.props;

const nav = [
  { href: '/#osteopathie', label: "L'ostéopathie" },
  { href: '/#pour-qui', label: 'Pour qui ?' },
  { href: '/#seance', label: 'La séance' },
  { href: '/#tarifs', label: 'Tarifs' },
  { href: '/#contact', label: 'Contact' },
];
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={new URL(Astro.url.pathname, Astro.site)} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="fr_FR" />
    <slot name="head" />
  </head>
  <body>
    <header class="site-header">
      <div class="container header-inner">
        <a href="/" class="brand">
          <span class="brand-name">{site.praticienne.nom}</span>
          <span class="brand-sub">{site.praticienne.titre}</span>
        </a>
        <button class="nav-toggle" aria-expanded="false" aria-controls="site-nav" aria-label="Menu">
          <span></span><span></span><span></span>
        </button>
        <nav id="site-nav" class="site-nav">
          {nav.map((item) => <a href={item.href}>{item.label}</a>)}
          <a class="btn btn-primary nav-cta" href={site.liens.doctolib} target="_blank" rel="noopener">
            Prendre rendez-vous
          </a>
        </nav>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <div class="container footer-inner">
        <div>
          <strong>{site.cabinet.nom}</strong><br />
          {site.cabinet.adresse}, {site.cabinet.codePostal} {site.cabinet.ville}<br />
          <a href={`tel:${site.cabinet.telephone.replace(/\s/g, '')}`}>{site.cabinet.telephone}</a>
        </div>
        <nav class="footer-nav">
          <a href="/femme-enceinte">Femme enceinte</a>
          <a href="/nourrisson">Nourrisson</a>
          <a href="/sportif">Sportif</a>
          <a href="/mentions-legales">Mentions légales</a>
        </nav>
      </div>
      <p class="footer-note container">
        L'ostéopathie ne se substitue pas à un suivi médical. En cas de doute, consultez votre médecin.
      </p>
    </footer>

    <script>
      const toggle = document.querySelector('.nav-toggle');
      const nav = document.getElementById('site-nav');
      toggle?.addEventListener('click', () => {
        const open = nav.classList.toggle('open');
        toggle.setAttribute('aria-expanded', String(open));
      });
      nav?.addEventListener('click', (e) => {
        if (e.target instanceof HTMLAnchorElement) {
          nav.classList.remove('open');
          toggle?.setAttribute('aria-expanded', 'false');
        }
      });
    </script>

    <style>
      .site-header {
        position: sticky;
        top: 0;
        z-index: 10;
        background: rgba(250, 248, 242, 0.95);
        backdrop-filter: blur(6px);
        border-bottom: 1px solid var(--green-100);
      }

      .header-inner {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        min-height: 4rem;
        flex-wrap: wrap;
        padding-block: 0.5rem;
      }

      .brand {
        text-decoration: none;
        display: flex;
        flex-direction: column;
        line-height: 1.2;
      }

      .brand-name {
        font-weight: 800;
        color: var(--green-900);
        font-size: 1.1rem;
      }

      .brand-sub {
        font-size: 0.85rem;
        color: var(--green-600);
        font-weight: 700;
      }

      .nav-toggle {
        display: flex;
        flex-direction: column;
        gap: 5px;
        background: none;
        border: none;
        padding: 0.5rem;
        cursor: pointer;
      }

      .nav-toggle span {
        width: 24px;
        height: 3px;
        border-radius: 2px;
        background: var(--green-900);
      }

      .site-nav {
        display: none;
        width: 100%;
        flex-direction: column;
        gap: 0.25rem;
        padding-bottom: 1rem;
      }

      .site-nav.open { display: flex; }

      .site-nav a {
        text-decoration: none;
        font-weight: 700;
        color: var(--ink);
        padding: 0.5rem 0;
      }

      .site-nav a:hover { color: var(--green-600); }

      .site-nav a.nav-cta {
        margin-top: 0.5rem;
        padding: 0.8rem 1.6rem;
        color: var(--white);
      }

      @media (min-width: 900px) {
        .nav-toggle { display: none; }

        .site-nav {
          display: flex;
          flex-direction: row;
          align-items: center;
          gap: 1.5rem;
          width: auto;
          padding-bottom: 0;
        }

        .site-nav a.nav-cta { margin-top: 0; }
      }

      .site-footer {
        background: var(--green-900);
        color: var(--green-100);
        padding-block: 2.5rem 1.5rem;
        margin-top: 3rem;
      }

      .site-footer a { color: var(--green-100); }

      .footer-inner {
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
      }

      .footer-nav {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem 1.5rem;
      }

      .footer-note {
        margin-top: 2rem;
        font-size: 0.85rem;
        opacity: 0.75;
      }

      @media (min-width: 768px) {
        .footer-inner {
          flex-direction: row;
          justify-content: space-between;
          align-items: flex-start;
        }
      }
    </style>
  </body>
</html>
