---
import { ClientRouter } from 'astro:transitions';
import figtreeWoff2 from '@fontsource-variable/figtree/files/figtree-latin-wght-normal.woff2?url';
import '@fontsource-variable/figtree';
import '../styles/global.css';
import { site } from '../data/site.js';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import themeScript from '../scripts/theme.js?raw';

const { title, description, hideFooterCta = false } = Astro.props;

const coords = JSON.stringify({
  lat: site.cabinet.latitude,
  lon: site.cabinet.longitude,
});
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={new URL(Astro.url.pathname, Astro.site)} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link
      rel="preload"
      href="/fonts/DTGetaiGroteskDisplay-Black-v2.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link rel="preload" href={figtreeWoff2} as="font" type="font/woff2" crossorigin />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="fr_FR" />
    <ClientRouter />
    <script is:inline set:html={`document.documentElement.classList.add('js');window.__SITE_COORDS=${coords};${themeScript}`} />
    <slot name="head" />
  </head>
  <body>
    <a class="skip-link" href="#contenu">Aller au contenu</a>
    <Nav />

    <main id="contenu">
      <slot />
    </main>

    <Footer hideCta={hideFooterCta} />

    <script>
      const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      const targets = document.querySelectorAll('.reveal');
      if (reduced || !('IntersectionObserver' in window)) {
        targets.forEach((el) => el.classList.add('is-visible'));
      } else {
        const io = new IntersectionObserver(
          (entries) => {
            for (const entry of entries) {
              if (entry.isIntersecting) {
                entry.target.classList.add('is-visible');
                io.unobserve(entry.target);
              }
            }
          },
          { rootMargin: '0px 0px -8% 0px' }
        );
        targets.forEach((el) => io.observe(el));
      }
    </script>

    <style>
      .skip-link {
        position: absolute;
        left: -9999px;
        top: 0;
        z-index: calc(var(--zindex-nav) + 1);
        background: var(--color-primary-accent);
        color: var(--color-text-tertiary);
        padding: 0.75rem 1.25rem;
        border-radius: 0 0 var(--radius-base) 0;
      }

      .skip-link:focus {
        left: 0;
      }
    </style>
  </body>
</html>
