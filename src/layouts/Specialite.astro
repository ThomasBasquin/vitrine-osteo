---
import Base from './Base.astro';
import Aura from '../components/Aura.astro';

const { title, description, h1, crumb, motifsTitre, pastel = 'pastel-mint' } = Astro.props;
---

<Base title={title} description={description}>
  <section class="page-hero spec-hero">
    <Aura />
    <p class="crumb">
      <a href="/">Accueil</a>
      <span class="crumb-sep" aria-hidden="true">·</span>
      <span class="crumb-current">{crumb}</span>
    </p>
    <h1>{h1}</h1>
  </section>

  <section class="spec-section">
    <div class="container spec-content">
      <slot />

      <div class={`motifs pastel ${pastel} reveal`}>
        <h2>{motifsTitre}</h2>
        <slot name="motifs" />
      </div>
      <p class="spec-note reveal">
        Cette liste n'est pas exhaustive : en cas de doute, n'hésitez pas à me contacter pour
        savoir si l'ostéopathie peut vous aider. L'ostéopathie ne se substitue pas à un suivi
        médical.
      </p>
    </div>
  </section>
</Base>

<style>
  .crumb {
    display: flex;
    justify-content: center;
    font-size: var(--font-mini);
    color: var(--color-text-secondary);
    padding-inline: clamp(1.25rem, 4vw, 2rem);
    margin: 0 0 0.75rem;
  }

  .crumb a {
    color: inherit;
    text-decoration: none;
  }

  .crumb a:hover {
    color: var(--color-text-primary);
  }

  .crumb-sep {
    margin: 0 0.35em;
    opacity: 0.6;
  }

  .crumb-current {
    color: var(--color-text-primary);
    font-weight: 600;
  }

  .spec-hero h1 {
    font-size: var(--font-h2-display);
    letter-spacing: -1px;
    max-width: 22ch;
    margin-inline: auto;
    padding-inline: clamp(1.25rem, 4vw, 2rem);
  }

  .spec-hero { padding-bottom: 0; }

  .spec-section { padding-top: var(--spacing-m); padding-bottom: var(--spacing-l); }

  .spec-content { max-width: 46rem; }

  .motifs { margin-top: var(--spacing-m); }

  .motifs h2 { font-size: var(--font-h3); }

  .motifs :global(ul) {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .motifs :global(li) {
    position: relative;
    padding: 0.5rem 0 0.5rem 1.6rem;
    font-size: var(--font-link);
    color: var(--color-green500);
  }

  .motifs :global(li)::before {
    content: '';
    position: absolute;
    left: 0.25rem;
    top: 1.05rem;
    width: 0.5rem;
    height: 0.5rem;
    border-radius: 50% 50% 50% 0;
    background: var(--color-green500);
  }

  .spec-note {
    font-size: var(--font-mini);
    margin-top: 1.75rem;
  }
</style>
