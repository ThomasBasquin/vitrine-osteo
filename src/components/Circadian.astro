---
const hours = Array.from({ length: 24 }, (_, h) => h);
---

<div class="circadian" data-circadian>
  <div class="hours">
    <button class="bubble" type="button" aria-label="Basculer entre le thème jour et le thème nuit">
      <svg class="icon-sun" width="22" height="22" viewBox="0 0 24 24" fill="none" aria-hidden="true">
        <circle cx="12" cy="12" r="4.5" fill="currentColor" />
        <g stroke="currentColor" stroke-width="1.8" stroke-linecap="round">
          <path d="M12 2.5v2.4M12 19.1v2.4M2.5 12h2.4M19.1 12h2.4M5.3 5.3l1.7 1.7M17 17l1.7 1.7M18.7 5.3L17 7M7 17l-1.7 1.7" />
        </g>
      </svg>
      <svg class="icon-moon" width="22" height="22" viewBox="0 0 24 24" fill="none" aria-hidden="true">
        <path d="M20.4 14.2A8.6 8.6 0 0 1 9.8 3.6a8.6 8.6 0 1 0 10.6 10.6Z" fill="currentColor" />
      </svg>
    </button>
    {hours.map((h) => (
      <button
        type="button"
        class="hour"
        data-hour={h}
        title={`${String(h).padStart(2, '0')}h`}
        aria-label={`Voir le thème à ${String(h).padStart(2, '0')}h`}
      >
        <span class="line"></span>
      </button>
    ))}
  </div>
</div>

<script>
  let stopCircadian: (() => void) | undefined;

  function initCircadian() {
    stopCircadian?.();

    const root = document.querySelector('[data-circadian]');
    if (!root) return;

    const bubble = root.querySelector<HTMLButtonElement>('.bubble')!;
    const hourEls = root.querySelectorAll<HTMLElement>('.hour');

    let manualHour: number | null = null;
    let hourlyTimeout: ReturnType<typeof setTimeout> | undefined;
    let hourlyInterval: ReturnType<typeof setInterval> | undefined;

    const update = (sunrise?: Date, sunset?: Date) => {
      const circadian = (window as any).__circadian;
      if (!circadian) return;
      const now = new Date();
      if (!sunrise || !sunset) {
        ({ sunrise, sunset } = circadian.sunTimes(now));
      }
      const riseH = sunrise!.getHours() + sunrise!.getMinutes() / 60;
      const setH = sunset!.getHours() + sunset!.getMinutes() / 60;
      const currentHour = manualHour ?? now.getHours();
      // Pas de bouclage 23h/0h : aux bornes de la bande, un seul voisin existe visuellement.
      const prevHour = currentHour > 0 ? currentHour - 1 : -1;
      const nextHour = currentHour < 23 ? currentHour + 1 : -1;

      hourEls.forEach((el) => {
        const h = Number(el.dataset.hour);
        const mid = h + 0.5;
        el.classList.toggle('day', mid >= riseH && mid <= setH);
        el.classList.toggle('near', h === prevHour || h === nextHour);
        el.classList.toggle('active', h === currentHour);
      });

      bubble.style.left = `${((currentHour + 0.5) / 24) * 100}%`;
    };

    const scheduleHourlyUpdate = () => {
      const now = new Date();
      const msToNextHour =
        (60 - now.getMinutes()) * 60000 - now.getSeconds() * 1000 - now.getMilliseconds();
      hourlyTimeout = setTimeout(() => {
        update();
        hourlyInterval = setInterval(update, 3600000);
      }, msToNextHour);
    };

    const onThemeChange = ((e: CustomEvent) =>
      update(e.detail.sunrise, e.detail.sunset)) as EventListener;
    document.addEventListener('themechange', onThemeChange);

    const onBubbleClick = () => (window as any).__circadian?.toggle();
    bubble.addEventListener('click', onBubbleClick);

    const hourClickHandlers: Array<[HTMLElement, () => void]> = [];
    hourEls.forEach((el) => {
      const handler = () => {
        const circadian = (window as any).__circadian;
        if (!circadian) return;
        const h = Number(el.dataset.hour);
        const { sunrise, sunset } = circadian.sunTimes(new Date());
        const riseH = sunrise.getHours() + sunrise.getMinutes() / 60;
        const setH = sunset.getHours() + sunset.getMinutes() / 60;
        const isDay = h + 0.5 >= riseH && h + 0.5 <= setH;
        manualHour = h;
        try {
          sessionStorage.setItem('theme', isDay ? 'light' : 'dark');
        } catch (e) {}
        circadian.apply();
      };
      el.addEventListener('click', handler);
      hourClickHandlers.push([el, handler]);
    });

    update();
    scheduleHourlyUpdate();

    stopCircadian = () => {
      document.removeEventListener('themechange', onThemeChange);
      bubble.removeEventListener('click', onBubbleClick);
      hourClickHandlers.forEach(([el, handler]) => el.removeEventListener('click', handler));
      if (hourlyTimeout) clearTimeout(hourlyTimeout);
      if (hourlyInterval) clearInterval(hourlyInterval);
    };
  }

  document.addEventListener('astro:page-load', initCircadian);
</script>

<style>
  .circadian {
    position: relative;
    max-width: 72rem;
    margin: var(--spacing-m) auto 0;
    padding: 100px clamp(1.25rem, 4vw, 2rem) var(--spacing-s);
  }

  .hours {
    position: relative;
    display: flex;
    width: 100%;
  }

  .hour {
    height: 40px;
    width: 100%;
    display: flex;
    align-items: flex-end;
    justify-content: center;
    overflow: hidden;
    background: none;
    border: 0;
    padding: 0;
    cursor: pointer;
    -webkit-tap-highlight-color: transparent;
  }

  .line {
    height: 40px;
    width: 2px;
    border-radius: 20px;
    background: var(--color-primary-accent);
    opacity: 0.2;
    /* Nuit = 12px visibles ; jour = ×1.5 ; near = ×1.5. Le trait actif ne suit plus
       cette progression : il est plus court (34px) mais décollé de 6px de la ligne de
       base commune, ce qui le fait flotter au lieu de simplement dépasser les autres. */
    transform: translate3d(0, 28px, 0);
    transition: transform 0.5s var(--curve), opacity 0.3s linear;
  }

  .hour.day .line { transform: translate3d(0, 22px, 0); opacity: 0.85; }

  /* La hauteur (near/active) est indépendante du jour/nuit ; seule la couleur
     s'éclaircit, et uniquement si le créneau tombe aussi de jour — sinon le
     trait reste dans son opacité de nuit, juste plus haut. */
  .hour.near .line { transform: translate3d(0, 13px, 0); }

  .hour.active .line { transform: translate3d(0, -6px, 0); }

  .hour.day.near .line,
  .hour.day.active .line {
    opacity: 1;
  }

  .hour:not(.active):hover .line { opacity: 1; transform: translate3d(0, 12px, 0); }

  .bubble {
    position: absolute;
    top: -24px;
    transform: translate(-50%, -100%);
    width: 44px;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-primary-accent);
    color: var(--color-text-tertiary);
    border: 0;
    border-radius: 50%;
    cursor: pointer;
    transition: left 0.5s var(--ease-out), filter 0.2s ease-in-out;
    /* left est posé par le script, en % de .hours pour rester aligné avec les traits d'heure */
    left: 50%;
  }

  .bubble:hover { filter: saturate(1.5); }

  .icon-moon { display: none; }

  :global(.dark) .icon-sun { display: none; }
  :global(.dark) .icon-moon { display: block; }
</style>
