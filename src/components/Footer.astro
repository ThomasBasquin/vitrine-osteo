---
import { site } from '../data/site.js';
import Circadian from './Circadian.astro';

const year = new Date().getFullYear();

const consultationLinks = [
  { href: '/pour-qui#femme-enceinte', label: 'Femme enceinte' },
  { href: '/pour-qui#nourrisson', label: 'Nourrisson' },
  { href: '/pour-qui#sportif', label: 'Sportif' },
  { href: '/seance#tarifs', label: 'Tarifs' },
];
---

<footer class="site-footer">
  <div class="container footer-grid">
    <p class="footer-name">{site.cabinet.nom}</p>
    <p class="footer-address">
      {site.cabinet.adresse}, {site.cabinet.codePostal} {site.cabinet.ville}
    </p>

    <nav class="footer-links" aria-label="Consultations">
      {consultationLinks.map((l, i) => (
        <>
          {i > 0 && <span class="dot" aria-hidden="true">·</span>}
          <a href={l.href}>{l.label}</a>
        </>
      ))}
    </nav>

    <p class="footer-legal">
      © {year} {site.praticienne.nom} · <a href="/mentions-legales">Mentions légales</a>
    </p>
  </div>

  <p class="container footer-note">
    L'ostéopathie ne se substitue pas à un suivi médical. En cas de doute, consultez votre médecin.
  </p>

  <Circadian />
</footer>

<style>
  .site-footer {
    position: relative;
    z-index: var(--zindex-base);
    padding-top: var(--spacing-s);
  }

  .footer-grid {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    text-align: center;
    padding-bottom: var(--spacing-m);
  }

  .footer-name {
    font-family: var(--titleFont);
    font-weight: 700;
    font-size: var(--font-link);
    color: var(--color-text-primary);
  }

  .footer-address, .footer-legal {
    font-size: var(--font-mini);
    color: var(--color-text-secondary);
  }

  .footer-links {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.5rem;
    margin-top: 0.25rem;
  }

  .footer-links a {
    font-size: var(--font-link);
    color: var(--color-text-secondary);
    text-decoration: none;
  }

  .footer-links a:hover { color: var(--color-text-primary); }

  .footer-links .dot { color: var(--color-light-border); }

  .footer-note {
    font-size: var(--font-mini);
    color: var(--color-text-secondary);
    text-align: center;
    margin-top: 0.75rem;
  }
</style>
