---
import { site } from '../data/site.js';

const links = [
  { href: '/', label: 'Accueil' },
  { href: '/seance', label: 'La séance' },
  { href: '/a-propos', label: 'À propos' },
  { href: '/contact', label: 'Contact' },
];

const path = Astro.url.pathname.replace(/\.html$/, '').replace(/\/+$/, '') || '/';
---

<header class="site-header">
  <nav aria-label="Navigation principale">
    <ul class="pill" data-nav-pill>
      {links.map((l) => (
        <li>
          <a href={l.href} class:list={[{ active: path === l.href }]} aria-current={path === l.href ? 'page' : undefined}>
            {l.label}
          </a>
        </li>
      ))}
      <li class="rdv-item">
        <a class="rdv" href={site.liens.doctolib} target="_blank" rel="noopener">Rendez-vous</a>
      </li>
    </ul>
  </nav>
</header>

<script>
  const pill = document.querySelector('[data-nav-pill]');
  const onScroll = () => pill?.classList.toggle('blur', window.scrollY > 40);
  onScroll();
  window.addEventListener('scroll', onScroll, { passive: true });
</script>

<style>
  .site-header {
    position: fixed;
    z-index: var(--zindex-nav);
    top: 0;
    left: 0;
    right: 0;
    padding: 0 1rem;
    pointer-events: none;
  }

  nav {
    display: flex;
    justify-content: center;
    max-width: var(--max-width);
    margin: 1.25rem auto 0;
  }

  .pill {
    pointer-events: auto;
    display: flex;
    align-items: center;
    list-style: none;
    margin: 0;
    padding: 0.625rem;
    border-radius: 50px;
    transition: background 0.2s linear;
  }

  .pill.blur {
    background: var(--color-backdrop);
    backdrop-filter: blur(20px) saturate(1.7);
    -webkit-backdrop-filter: blur(20px) saturate(1.7);
  }

  li { display: flex; }

  a {
    display: flex;
    align-items: center;
    font-size: var(--font-link);
    color: var(--color-text-secondary);
    text-decoration: none;
    border-radius: 24px;
    padding: 0.375rem 0.625rem;
    margin: 0 2px;
    transition: all 0.2s ease-in-out;
    white-space: nowrap;
  }

  a:hover { color: var(--color-text-primary); background: var(--color-white50); }

  a.active {
    color: var(--color-text-primary);
    background: var(--color-white50);
    font-weight: 600;
  }

  .rdv {
    background: var(--color-primary-accent);
    color: var(--color-text-tertiary);
    font-weight: 600;
  }

  .rdv:hover {
    color: var(--color-text-tertiary);
    background: var(--color-primary-accent);
    filter: saturate(1.5);
  }

  @media (min-width: 768px) {
    a { padding: 0.375rem 1.25rem; margin: 0 5px; }
  }

  @media (max-width: 640px) {
    .rdv-item { display: none; }
  }

  @media (max-width: 374px) {
    a { font-size: 0.8rem; padding: 0.375rem 0.45rem; }
  }
</style>
