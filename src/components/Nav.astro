---
import { site } from '../data/site.js';

const links = [
  { href: '/', label: 'Accueil' },
  { href: '/seance', label: 'La séance' },
];

const specialites = [
  { href: '/femme-enceinte', label: 'Femme enceinte' },
  { href: '/nourrisson', label: 'Nourrisson' },
  { href: '/sportif', label: 'Sportif' },
];

const path = Astro.url.pathname.replace(/\.html$/, '').replace(/\/+$/, '') || '/';
const specialitesActive = specialites.some((s) => s.href === path);
---

<header class="site-header">
  <nav aria-label="Navigation principale">
    <div class="pill" data-nav-pill>
      <ul class="pill-row">
        {links.map((l, i) => (
          <li>
            <a href={l.href} class:list={[{ active: path === l.href }]} aria-current={path === l.href ? 'page' : undefined}>
              {path === l.href && <span class="active-pill" transition:name="nav-active-pill" />}
              <span class="nav-label" transition:name={`nav-label-${i}`}>{l.label}</span>
            </a>
          </li>
        ))}
        <li class="dropdown" data-dropdown>
          <button
            type="button"
            class:list={['dropdown-trigger', { active: specialitesActive }]}
            aria-haspopup="true"
            aria-expanded="false"
            aria-controls="pour-qui-menu"
          >
            {specialitesActive && <span class="active-pill" transition:name="nav-active-pill" />}
            <span class="nav-label" transition:name="nav-label-2">Pour qui</span>
            <svg class="dropdown-caret" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M6 9l6 6 6-6" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </button>
        </li>
        <li>
          <a href="/contact" class:list={[{ active: path === '/contact' }]} aria-current={path === '/contact' ? 'page' : undefined}>
            {path === '/contact' && <span class="active-pill" transition:name="nav-active-pill" />}
            <span class="nav-label" transition:name="nav-label-3">Contact</span>
          </a>
        </li>
        <li class="rdv-item">
          <a class="rdv" href={site.liens.doctolib} target="_blank" rel="noopener">Rendez-vous</a>
        </li>
      </ul>
      <ul id="pour-qui-menu" class="dropdown-menu" data-dropdown-menu>
        {specialites.map((s) => (
          <li>
            <a href={s.href} class:list={[{ active: path === s.href }]}>{s.label}</a>
          </li>
        ))}
      </ul>
    </div>
  </nav>
</header>

<script>
  let stopScrollWatch: (() => void) | undefined;

  function initNavPill() {
    stopScrollWatch?.();
    const pill = document.querySelector('[data-nav-pill]');
    const onScroll = () => pill?.classList.toggle('blur', window.scrollY > 40);
    onScroll();
    window.addEventListener('scroll', onScroll, { passive: true });
    stopScrollWatch = () => window.removeEventListener('scroll', onScroll);
  }

  let stopDropdown: (() => void) | undefined;

  function initDropdown() {
    stopDropdown?.();
    const pill = document.querySelector<HTMLDivElement>('[data-nav-pill]');
    const pillRow = document.querySelector<HTMLUListElement>('.pill-row');
    const dropdown = document.querySelector<HTMLLIElement>('[data-dropdown]');
    const trigger = dropdown?.querySelector<HTMLButtonElement>('.dropdown-trigger');
    const menu = document.querySelector<HTMLUListElement>('[data-dropdown-menu]');
    if (!pill || !pillRow || !dropdown || !trigger || !menu) return;

    // Le menu est une simple section à l'intérieur de la pilule (qui s'allonge
    // à l'ouverture), pas un panneau flottant séparé : un seul élément flouté,
    // donc aucune jonction à raccorder entre deux flous indépendants. Sa largeur
    // reste étroite (sous le bouton) grâce à un clip-path calculé en JS plutôt
    // qu'à un second élément positionné, qui recréerait le même problème.
    const R1 = 999; // rayon des extrémités de la pilule, saturé à la moitié de sa hauteur
    const R2 = 18; // rayon des coins bas du menu
    const R3 = 12; // rayon (creux) des deux coins où le menu se détache de la pilule

    const applyShape = () => {
      const pillRect = pill.getBoundingClientRect();
      const rowH = pillRow.getBoundingClientRect().height;
      const triggerRect = trigger.getBoundingClientRect();
      const rowW = pillRect.width;
      const ddW = menu.offsetWidth;
      const ddH = menu.offsetHeight;
      const margin = 10;
      const triggerCenter = triggerRect.left - pillRect.left + triggerRect.width / 2;
      const ddLeft = Math.max(margin, Math.min(triggerCenter - ddW / 2, rowW - ddW - margin));
      const totalH = rowH + ddH;
      const r1 = Math.min(R1, rowH / 2);
      const r2 = Math.min(R2, ddH / 2, ddW / 2);
      const r3 = Math.min(R3, ddW / 4);

      // Les deux extrémités de la ligne (loin du dropdown) gardent un capuchon
      // arrondi complet, comme la pilule fermée : un seul arc à 180° (et non
      // deux quarts de cercle, dont les centres divergeaient légèrement et
      // donnaient un capuchon pointu/asymétrique plutôt qu'un vrai demi-cercle).
      // Coins creux (sweep 0, à l'inverse des coins pleins en sweep 1) là où le
      // menu, plus étroit, se détache du bord bas de la pilule : un angle droit
      // à cet endroit tranchait avec le reste du site, tout en arrondis.
      const d = [
        `M ${r1},0`,
        `L ${rowW - r1},0`,
        `A ${r1},${r1} 0 1 1 ${rowW - r1},${rowH}`,
        `L ${ddLeft + ddW + r3},${rowH}`,
        `A ${r3},${r3} 0 0 0 ${ddLeft + ddW},${rowH + r3}`,
        `L ${ddLeft + ddW},${totalH - r2}`,
        `A ${r2},${r2} 0 0 1 ${ddLeft + ddW - r2},${totalH}`,
        `L ${ddLeft + r2},${totalH}`,
        `A ${r2},${r2} 0 0 1 ${ddLeft},${totalH - r2}`,
        `L ${ddLeft},${rowH + r3}`,
        `A ${r3},${r3} 0 0 0 ${ddLeft - r3},${rowH}`,
        `L ${r1},${rowH}`,
        `A ${r1},${r1} 0 1 1 ${r1},0`,
        'Z',
      ].join(' ');
      // `.pill` garde `border-radius: 50px` en CSS pour l'état fermé. Sur la
      // pilule ouverte (haute de ~190px), 50px ne sature plus à mi-hauteur : il
      // s'applique alors littéralement aux coins, en plus du clip-path, et les
      // deux arrondis se combinent pour déformer la courbe du capuchon. On le
      // neutralise donc dès que le clip-path prend le relais.
      pill.style.borderRadius = '0';
      pill.style.clipPath = `path("${d}")`;
      menu.style.marginLeft = `${ddLeft}px`;
    };

    const open = () => {
      dropdown.classList.add('open');
      menu.classList.add('open');
      pill.classList.add('blur');
      trigger.setAttribute('aria-expanded', 'true');
      applyShape();
    };

    const close = () => {
      dropdown.classList.remove('open');
      menu.classList.remove('open');
      pill.style.clipPath = '';
      pill.style.borderRadius = '';
      if (window.scrollY <= 40) pill.classList.remove('blur');
      trigger.setAttribute('aria-expanded', 'false');
    };

    const onTriggerClick = (e: MouseEvent) => {
      e.stopPropagation();
      // Le curseur reste sur le bouton après le clic (ouverture comme
      // fermeture) : sans ça, le survol reprend aussitôt la même couleur
      // que l'état actif de la page. On le coupe jusqu'à ce que la souris
      // quitte réellement le bouton.
      trigger.classList.add('no-hover-flash');
      if (dropdown.classList.contains('open')) close();
      else open();
    };

    const onTriggerMouseLeave = () => trigger.classList.remove('no-hover-flash');

    const onDocClick = (e: MouseEvent) => {
      if (!pill.contains(e.target as Node)) close();
    };

    const onKeydown = (e: KeyboardEvent) => {
      if (e.key === 'Escape') close();
    };

    const onResize = () => {
      if (dropdown.classList.contains('open')) applyShape();
    };

    trigger.addEventListener('click', onTriggerClick);
    trigger.addEventListener('mouseleave', onTriggerMouseLeave);
    document.addEventListener('click', onDocClick);
    document.addEventListener('keydown', onKeydown);
    window.addEventListener('resize', onResize);

    stopDropdown = () => {
      trigger.removeEventListener('click', onTriggerClick);
      trigger.removeEventListener('mouseleave', onTriggerMouseLeave);
      document.removeEventListener('click', onDocClick);
      document.removeEventListener('keydown', onKeydown);
      window.removeEventListener('resize', onResize);
    };
  }

  document.addEventListener('astro:page-load', initNavPill);
  document.addEventListener('astro:page-load', initDropdown);
</script>

<style>
  .site-header {
    position: fixed;
    z-index: var(--zindex-nav);
    top: 0;
    left: 0;
    right: 0;
    padding: 0 1rem;
    pointer-events: none;
  }

  nav {
    display: flex;
    justify-content: center;
    max-width: var(--max-width);
    margin: 1.25rem auto 0;
  }

  .pill {
    pointer-events: auto;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    overflow: hidden;
    border-radius: 50px;
    transition: background 0.2s linear;
  }

  .pill.blur {
    background: var(--color-backdrop);
    backdrop-filter: blur(20px) saturate(1.7);
    -webkit-backdrop-filter: blur(20px) saturate(1.7);
  }

  .pill-row {
    display: flex;
    align-items: center;
    list-style: none;
    margin: 0;
    padding: 0.625rem;
  }

  li { display: flex; }

  a, .dropdown-trigger {
    position: relative;
    display: flex;
    align-items: center;
    font-family: var(--bodyFont);
    font-size: var(--font-link);
    color: var(--color-text-secondary);
    text-decoration: none;
    border: none;
    background: none;
    border-radius: 24px;
    padding: 0.375rem 0.625rem;
    margin: 0 2px;
    cursor: pointer;
    transition: background 0.2s ease-in-out;
    white-space: nowrap;
  }

  a:hover, .dropdown-trigger:hover { color: var(--color-text-primary); background: var(--color-white50); }

  a.active, .dropdown-trigger.active {
    color: var(--color-text-primary);
    font-weight: 600;
  }

  .active-pill {
    position: absolute;
    inset: 0;
    z-index: -1;
    border-radius: 24px;
    background: var(--color-white50);
    box-shadow: inset 0 0 0 1px var(--color-light-border);
  }

  .dropdown-trigger { gap: 0.3rem; }

  /* Le survol du déclencheur reprend le fond de la pastille active (même
     couleur), ce qui le fait passer pour "actif" dès qu'on clique pour
     ouvrir ou fermer le menu (le curseur reste dessus) — ou reste "collé"
     au doigt sur tactile. `.no-hover-flash` coupe le survol jusqu'à ce que
     la souris quitte réellement le bouton (voir script ci-dessus). */
  .dropdown-trigger.no-hover-flash:hover:not(.active) {
    color: var(--color-text-secondary);
    background: none;
  }

  .dropdown-caret {
    width: 0.8rem;
    height: 0.8rem;
    transition: rotate 0.25s var(--ease-out);
  }

  .dropdown.open .dropdown-caret { rotate: 180deg; }

  .dropdown-menu {
    display: none;
    flex-direction: column;
    gap: 0.15rem;
    width: max-content;
    margin: 0;
    padding: 0.4rem;
    list-style: none;
  }

  .dropdown-menu.open { display: flex; }

  .dropdown-menu li { display: block; }

  .dropdown-menu a {
    display: block;
    margin: 0;
    padding: 0.6rem 0.75rem;
    border-radius: 12px;
  }

  .rdv {
    background: var(--color-primary-accent);
    color: var(--color-text-tertiary);
    font-weight: 600;
  }

  .rdv:hover {
    color: var(--color-text-tertiary);
    background: var(--color-primary-accent);
    filter: saturate(1.5);
  }

  @media (min-width: 768px) {
    a, .dropdown-trigger { padding: 0.375rem 1.25rem; margin: 0 5px; }
  }

  @media (max-width: 640px) {
    .rdv-item { display: none; }
  }

  @media (max-width: 374px) {
    a, .dropdown-trigger { font-size: 0.8rem; padding: 0.375rem 0.45rem; }
  }
</style>

<style is:global>
  ::view-transition-group(nav-active-pill) {
    animation-duration: 0.28s;
    animation-timing-function: cubic-bezier(0.22, 1, 0.36, 1);
  }

  /* Le libellé a aussi son propre calque (au-dessus de la pastille, dans l'ordre
     du DOM) pour ne pas être recouvert pendant que la pastille glisse dessus ;
     lui-même ne doit pas animer, seule la pastille se déplace. */
  ::view-transition-group(nav-label-0),
  ::view-transition-group(nav-label-1),
  ::view-transition-group(nav-label-2),
  ::view-transition-group(nav-label-3),
  ::view-transition-old(nav-label-0),
  ::view-transition-old(nav-label-1),
  ::view-transition-old(nav-label-2),
  ::view-transition-old(nav-label-3),
  ::view-transition-new(nav-label-0),
  ::view-transition-new(nav-label-1),
  ::view-transition-new(nav-label-2),
  ::view-transition-new(nav-label-3) {
    animation-duration: 1ms;
  }

  @media (prefers-reduced-motion: reduce) {
    ::view-transition-group(nav-active-pill),
    ::view-transition-old(nav-active-pill),
    ::view-transition-new(nav-active-pill) {
      animation: none;
    }
  }
</style>
