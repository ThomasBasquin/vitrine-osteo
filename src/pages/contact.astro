---
import Base from '../layouts/Base.astro';
import Aura from '../components/Aura.astro';
import Email from '../components/Email.astro';
import { site } from '../data/site.js';

const title = `Contact & accès — ${site.cabinet.nom}`;
const description =
  `Contacter ${site.cabinet.nom}, cabinet d'ostéopathie à ${site.cabinet.ville} : ` +
  'téléphone, email, horaires, plan d\'accès. Prise de rendez-vous en ligne via Doctolib.';

const tel = site.cabinet.telephone.replace(/\s/g, '');
const itineraire = `https://www.google.com/maps/dir/?api=1&destination=${encodeURIComponent(
  `${site.cabinet.adresse}, ${site.cabinet.codePostal} ${site.cabinet.ville}`
)}`;
---

<Base title={title} description={description}>
  <section class="page-hero">
    <Aura />
    <h1>Contact</h1>
    <p class="page-lead">
      Pour la prise de rendez-vous, vous pouvez me joindre par téléphone ou réserver
      directement un créneau en ligne via Doctolib.
    </p>
    <div class="hero-actions">
      <a class="btn btn-primary" href={site.liens.doctolib} target="_blank" rel="noopener">
        Prendre rendez-vous
      </a>
    </div>
  </section>

  <section>
    <div class="container contact-grid">
      <div class="contact-info reveal">
        <ul class="contact-list">
          <li>
            <span class="contact-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z" />
                <circle cx="12" cy="10" r="3" />
              </svg>
            </span>
            <div>
              <span class="visually-hidden">Adresse</span>
              <address>
                {site.cabinet.adresse}<br />
                {site.cabinet.codePostal} {site.cabinet.ville}
              </address>
              <span class="contact-extra">{site.cabinet.parking}</span>
            </div>
          </li>
          <li>
            <span class="contact-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z" />
              </svg>
            </span>
            <div>
              <span class="visually-hidden">Téléphone</span>
              <a href={`tel:${tel}`}>{site.cabinet.telephone}</a>
            </div>
          </li>
          <li>
            <span class="contact-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                <rect x="2" y="4" width="20" height="16" rx="2" />
                <polyline points="22,6 12,13 2,6" />
              </svg>
            </span>
            <div>
              <span class="visually-hidden">Email</span>
              <Email class="contact-email-link" />
            </div>
          </li>
          <li>
            <span class="contact-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="10" />
                <polyline points="12,6 12,12 16,14" />
              </svg>
            </span>
            <div>
              <span class="visually-hidden">Horaires</span>
              <ul class="horaires">
                {site.horaires.map((h) => (
                  <li>
                    <span>{h.jours}</span>
                    <strong>{h.heures}</strong>
                  </li>
                ))}
              </ul>
            </div>
          </li>
        </ul>
      </div>
      <div class="map-wrap reveal" style="--reveal-delay: 0.12s">
        <div
          id="map"
          data-lat={site.cabinet.latitude}
          data-lon={site.cabinet.longitude}
          data-nom={site.cabinet.nom}
        ></div>
        <a class="map-link" href={itineraire} target="_blank" rel="noopener">
          Itinéraire vers le cabinet<span aria-hidden="true"> →</span>
        </a>
      </div>
    </div>
  </section>
</Base>

<script>
  import L from 'leaflet';
  import 'leaflet/dist/leaflet.css';

  const el = document.getElementById('map');
  if (el) {
    const lat = Number(el.dataset.lat);
    const lon = Number(el.dataset.lon);
    const map = L.map(el, { scrollWheelZoom: false, attributionControl: false }).setView(
      [lat, lon],
      14
    );
    L.control
      .attribution({ prefix: false })
      .addAttribution('© <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a>')
      .addTo(map);
    L.tileLayer('https://tile.openstreetmap.org/{z}/{x}/{y}.png', { maxZoom: 19 }).addTo(map);
    L.marker([lat, lon], {
      icon: L.divIcon({
        className: '',
        html: '<div class="cabinet-marker"></div>',
        iconSize: [34, 34],
        iconAnchor: [17, 41],
      }),
    })
      .addTo(map)
      .bindPopup(el.dataset.nom ?? '');
  }
</script>

<style>
  .page-lead {
    text-align: center;
    max-width: 36rem;
    margin: var(--spacing-s) auto 0;
    padding-inline: clamp(1.25rem, 4vw, 2rem);
  }

  .hero-actions {
    display: flex;
    justify-content: center;
    margin-top: var(--spacing-l);
  }

  .contact-grid {
    display: grid;
    gap: var(--spacing-l);
    align-items: start;
  }

  @media (min-width: 820px) {
    .contact-grid { grid-template-columns: 2fr 3fr; }
  }

  .contact-list {
    margin: 0 0 2rem;
    padding: 0;
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--spacing-s);
  }

  .contact-list > li {
    display: flex;
    align-items: flex-start;
    gap: 0.9rem;
  }

  .contact-icon {
    display: inline-flex;
    flex-shrink: 0;
    align-items: center;
    justify-content: center;
    width: 1.4rem;
    height: 1.4rem;
    margin-top: 0.2rem;
    color: var(--color-primary-accent);
  }

  .contact-icon svg { width: 100%; height: 100%; }

  .contact-list > li > div {
    font-size: var(--font-body);
    color: var(--color-text-secondary);
  }

  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .contact-list address { font-style: normal; }

  .contact-list a { color: var(--color-text-secondary); }

  .contact-list a:hover { color: var(--color-text-primary); }

  .contact-list :global(.contact-email-link) { color: var(--color-text-secondary); }

  .contact-list :global(.contact-email-link):hover { color: var(--color-text-primary); }

  .contact-extra {
    display: block;
    margin-top: 0.2rem;
    font-size: var(--font-mini);
  }

  .horaires {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .horaires li {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    padding: 0.2rem 0;
  }

  .horaires strong { color: var(--color-text-primary); }

  .map-wrap {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  #map {
    width: 100%;
    min-height: 380px;
    border-radius: var(--radius-card);
    border: 1px solid var(--color-light-border);
    z-index: var(--zindex-map);
  }

  #map :global(.cabinet-marker) {
    width: 34px;
    height: 34px;
    border-radius: 50% 50% 50% 0;
    transform: rotate(-45deg);
    background: var(--color-green500);
    border: 3px solid var(--color-white);
    box-shadow: 0 2px 6px rgba(0, 0, 0, 0.35);
  }

  .map-link {
    align-self: flex-start;
    font-weight: 600;
    text-decoration: none;
  }

  .map-link:hover { text-decoration: underline; text-underline-offset: 4px; }
</style>
