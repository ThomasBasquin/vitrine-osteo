---
import Base from '../layouts/Base.astro';
import Aura from '../components/Aura.astro';
import { site } from '../data/site.js';

const title = `À propos — ${site.cabinet.nom}`;
const description =
  `${site.praticienne.nom}, ${site.praticienne.titre} diplômée du ${site.praticienne.ecole}. ` +
  'Ostéopathie structurelle, approche globale et personnalisée.';

const experiences = [
  { lieu: 'CHU Hautepierre, Strasbourg', detail: 'gynécologie, obstétrique' },
  { lieu: 'Clinique du Ried, Schiltigheim', detail: 'soins médicaux et de réadaptation à orientation gériatrique' },
  { lieu: 'Clinique Sainte-Anne, Strasbourg', detail: 'oncologie, soins palliatifs, chirurgie orthopédique' },
  { lieu: 'Nouvel Hôpital Civil, Strasbourg', detail: null },
  { lieu: 'Clinique Sainte-Barbe, Strasbourg', detail: null },
  { lieu: 'Clinique Toussaint, Strasbourg', detail: null },
];
---

<Base title={title} description={description}>
  <section class="page-hero">
    <Aura />
    <h1>Marie Wach</h1>
  </section>

  <section class="presentation">
    <div class="container presentation-grid">
      <figure class="portrait reveal">
        <img
          src="/images/portrait-placeholder.svg"
          alt={`Portrait de ${site.praticienne.nom}, ostéopathe`}
          width="400"
          height="500"
        />
      </figure>
      <div class="presentation-text reveal" style="--reveal-delay: 0.12s">
        <h2 class="h2-display">
          Ostéopathe D.O., diplômée du {site.praticienne.ecole}.
        </h2>
        <p>
          Je pratique une ostéopathie complète, alliant techniques douces (fonctionnelles,
          tissulaires) et techniques structurelles (myotensives, HVBA).
        </p>
        <p>
          Mon approche globale et personnalisée vise à restaurer l'équilibre du corps et à
          accompagner chaque patient vers un mieux-être durable.
        </p>
      </div>
    </div>
  </section>

  <section>
    <div class="container exp-wrap">
      <h2 class="reveal">Expériences cliniques</h2>
      <ul class="exp-list reveal">
        {experiences.map((e) => (
          <li>
            <strong>{e.lieu}</strong>
            {e.detail && <span> — {e.detail}</span>}
          </li>
        ))}
      </ul>
    </div>
  </section>
</Base>

<style>
  .presentation-grid {
    display: grid;
    gap: var(--spacing-l);
    align-items: center;
  }

  @media (min-width: 820px) {
    .presentation-grid { grid-template-columns: 2fr 3fr; }
  }

  .portrait {
    margin: 0;
    justify-self: center;
  }

  .portrait img {
    width: min(340px, 78vw);
    border-radius: 999px 999px var(--radius-card) var(--radius-card);
  }

  .presentation-text h2 { margin-bottom: var(--spacing-xs); }

  .exp-wrap { max-width: 46rem; }

  .exp-list {
    list-style: none;
    padding: 0;
    margin: var(--spacing-s) 0 0;
  }

  .exp-list li {
    padding: 0.75rem 0;
    border-bottom: 1px solid var(--color-light-border);
    font-size: var(--font-body);
    color: var(--color-text-secondary);
  }

  .exp-list li:last-child { border-bottom: none; }

  .exp-list strong { color: var(--color-text-primary); }
</style>
