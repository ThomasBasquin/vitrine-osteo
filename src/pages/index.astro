---
import Base from '../layouts/Base.astro';
import Aura from '../components/Aura.astro';
import { site } from '../data/site.js';

const title = `${site.praticienne.nom} — Ostéopathe à ${site.cabinet.ville}`;
const description =
  `Cabinet d'ostéopathie à ${site.cabinet.ville}. Adultes, femmes enceintes, nourrissons et sportifs. ` +
  'Techniques douces et structurelles, approche globale et personnalisée. Prise de rendez-vous en ligne.';

const publics = [
  {
    titre: 'Adultes',
    texte:
      "Tensions musculaires, troubles posturaux, stress, troubles digestifs ou céphalées : une approche globale pour restaurer la mobilité des tissus et améliorer le confort de vie, en prévention comme en traitement ponctuel.",
    lien: null,
    pastel: 'pastel-mint',
  },
  {
    titre: 'Femmes enceintes',
    texte:
      "Aider le corps à s'adapter aux changements posturaux, hormonaux et mécaniques de la grossesse : douleurs lombaires, sciatiques, reflux, troubles circulatoires ou gênes thoraciques.",
    lien: '/femme-enceinte',
    pastel: 'pastel-lilac',
  },
  {
    titre: 'Nourrissons',
    texte:
      "Améliorer le confort des nouveau-nés après la naissance : torticolis, plagiocéphalie, troubles du sommeil, régurgitations, coliques ou difficultés d'allaitement.",
    lien: '/nourrisson',
    pastel: 'pastel-babyblue',
  },
  {
    titre: 'Sportifs',
    texte:
      "Optimiser les performances en améliorant la mobilité articulaire, la récupération musculaire et la prévention des blessures, pour un geste sportif fluide et efficace.",
    lien: '/sportif',
    pastel: 'pastel-rust',
  },
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'MedicalBusiness',
  name: site.cabinet.nom,
  description: "Cabinet d'ostéopathie — adultes, femmes enceintes, nourrissons et sportifs.",
  url: Astro.site?.toString(),
  telephone: site.cabinet.telephone,
  address: {
    '@type': 'PostalAddress',
    streetAddress: site.cabinet.adresse,
    postalCode: site.cabinet.codePostal,
    addressLocality: site.cabinet.ville,
    addressCountry: 'FR',
  },
  ...(site.cabinet.latitude && {
    geo: {
      '@type': 'GeoCoordinates',
      latitude: site.cabinet.latitude,
      longitude: site.cabinet.longitude,
    },
  }),
};
---

<Base title={title} description={description}>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} slot="head" />

  <section class="page-hero home-hero">
    <Aura />
    <div class="hero-content">
      <h1>
        <span class="hero-line">Marie Wach.</span>
        <span class="hero-line">Ostéopathe D.O.</span>
      </h1>
      <p class="hero-lead">
        Une ostéopathie douce et globale à {site.cabinet.ville} — pour les adultes,
        femmes enceintes, nourrissons et sportifs.
      </p>
      <div class="hero-actions">
        <a class="btn btn-primary" href={site.liens.doctolib} target="_blank" rel="noopener">
          Prendre rendez-vous
        </a>
        <a class="btn btn-outline" href="/contact">Me contacter</a>
      </div>
    </div>
  </section>

  <section class="definition-section">
    <div class="container">
      <blockquote class="definition reveal">
        L'ostéopathie est une thérapie manuelle douce et globale qui aide à soulager les
        douleurs et à libérer les tensions du corps. Son objectif&nbsp;: permettre au corps
        de retrouver son équilibre, sa mobilité et sa capacité d'adaptation au quotidien.
      </blockquote>
      <p class="definition-more reveal">
        <a href="/seance">Découvrir le déroulement d'une séance →</a>
      </p>
    </div>
  </section>

  <section class="publics-section">
    <div class="container-wide">
      <h2 class="h2-display publics-title reveal">Pour qui&nbsp;?</h2>
      <div class="publics">
        {publics.map((p, i) => (
          <article class={`public pastel ${p.pastel} reveal`} style={`--reveal-delay: ${i * 0.08}s`}>
            <h3>{p.titre}</h3>
            <p>{p.texte}</p>
            {p.lien && (
              <a class="public-link" href={p.lien}>
                En savoir plus<span aria-hidden="true"> →</span>
              </a>
            )}
          </article>
        ))}
      </div>
    </div>
  </section>
</Base>

<style>
  .home-hero {
    padding-bottom: var(--spacing-xl);
    overflow: hidden;
  }

  .hero-content {
    max-width: var(--max-width);
    margin-inline: auto;
    padding-inline: clamp(1.25rem, 4vw, 2rem);
    text-align: center;
  }

  .hero-line { display: block; }

  .hero-lead {
    max-width: 36rem;
    margin: var(--spacing-s) auto 0;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    align-items: center;
    gap: 1rem;
    margin-top: var(--spacing-m);
  }

  /* Entrée du hero */
  html.js .hero-content > * {
    animation: hero-in 0.9s var(--ease-out) both;
  }

  html.js .hero-content h1 { animation-delay: 0.05s; }
  html.js .hero-content .hero-lead { animation-delay: 0.18s; }
  html.js .hero-content .hero-actions { animation-delay: 0.3s; }

  @keyframes hero-in {
    from { opacity: 0; translate: 0 28px; }
    to { opacity: 1; translate: 0 0; }
  }

  .definition-section .container { max-width: 52rem; }

  .definition {
    margin: 0;
    padding: 0;
    border: none;
    font-family: var(--titleFont);
    font-size: clamp(1.4rem, 1.1rem + 1.4vw, 2.2rem);
    font-weight: 600;
    line-height: 145%;
    color: var(--color-text-primary);
    text-align: center;
    text-wrap: balance;
  }

  .definition-more {
    text-align: center;
    margin: var(--spacing-s) 0 0;
  }

  .definition-more a {
    font-weight: 600;
    text-decoration: none;
  }

  .definition-more a:hover { text-decoration: underline; }

  .publics-title {
    text-align: center;
    margin-bottom: var(--spacing-l);
  }

  .publics {
    display: grid;
    gap: 1.5rem;
  }

  @media (min-width: 720px) {
    .publics { grid-template-columns: repeat(2, 1fr); }
  }

  .public {
    position: relative;
    display: flex;
    flex-direction: column;
    transition: transform 0.3s var(--ease-out);
  }

  .public:has(.public-link):hover { transform: translateY(-4px); }

  .public h3 { margin-bottom: 0.5rem; }

  .public p { margin-bottom: 0; font-size: var(--font-link); }

  .public-link {
    margin-top: 1.25rem;
    font-weight: 700;
    text-decoration: none;
  }

  /* Toute la carte est cliquable */
  .public-link::after {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: var(--radius-card);
  }

  .public-link:hover { text-decoration: underline; text-underline-offset: 4px; }
</style>
