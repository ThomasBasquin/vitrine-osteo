---
import Base from '../layouts/Base.astro';
import Aura from '../components/Aura.astro';
import { site } from '../data/site.js';

const title = `La séance & tarifs — ${site.cabinet.nom}`;
const description =
  "Le déroulement d'une séance d'ostéopathie : anamnèse, tests médicaux, bilan et traitement, " +
  'conseils. Environ 45 minutes. Tarifs des consultations et questions fréquentes.';

const etapes = [
  {
    titre: 'Accueil & anamnèse',
    texte:
      "La séance débute par un temps d'échange : motif de consultation, antécédents et mode de vie, pour identifier la cause de vos douleurs.",
  },
  {
    titre: 'Tests médicaux',
    texte:
      "Un examen clinique permet de vérifier que votre douleur relève bien du champ de compétences de l'ostéopathie, avec réorientation vers un médecin si nécessaire.",
  },
  {
    titre: 'Bilan ostéopathique & traitement',
    texte:
      "Des tests ostéopathiques identifient les dysfonctions, suivis d'un traitement manuel personnalisé, adapté à votre corps et à vos ressentis.",
  },
  {
    titre: 'Conseils de fin de séance',
    texte:
      "La consultation se termine par des conseils sur vos habitudes de vie ou des exercices simples à réaliser chez vous, et l'éventuelle reprise de rendez-vous pour le suivi.",
  },
];

const faq = [
  {
    q: "Quelle tenue pour une séance d'ostéopathie ?",
    a: "Il est essentiel que vous vous sentiez à l'aise : privilégiez des tenues confortables et souples (tenue de sport, legging…).",
  },
  {
    q: 'La séance est-elle remboursée ?',
    a: "L'ostéopathie ne dépend pas du parcours de soin remboursé par la Sécurité sociale, mais la plupart des mutuelles prennent en charge une ou plusieurs séances par an. Une facture vous est remise à transmettre à votre mutuelle.",
  },
  {
    q: 'Que faire après une séance ?',
    a: "La séance aide votre corps à retrouver la mobilité qu'il avait perdue : vous pouvez donc rester actif après la séance et vivre normalement.",
  },
  {
    q: 'Quels sont les moyens de paiement acceptés ?',
    a: 'Le règlement se fait en espèces ou par carte bancaire.',
  },
];
---

<Base title={title} description={description}>
  <section class="page-hero">
    <Aura />
    <h1>La séance</h1>
    <p class="page-lead">
      Une consultation dure de 45 minutes à 1 heure selon son déroulement
      et vos besoins.
    </p>
  </section>

  <section class="etapes-section">
    <div class="container seance-inner">
      <ol class="etapes">
        {etapes.map((e, i) => (
          <li class="etape reveal" style={`--reveal-delay: ${i * 0.08}s`}>
            <span class="etape-num" aria-hidden="true">
              <svg viewBox="0 0 100 100">
                <text x="50" y="52" text-anchor="middle" dominant-baseline="central">{i + 1}</text>
              </svg>
            </span>
            <div>
              <h3>{e.titre}</h3>
              <p>{e.texte}</p>
            </div>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <section id="tarifs">
    <div class="container seance-inner">
      <h2 class="h2-display reveal">Tarifs</h2>
      <div class="tarif-card reveal">
        <ul class="tarif-list">
          {site.tarifs.map((t) => (
            <li>
              <span>{t.label}</span>
              <strong class="tarif-prix">{t.prix}</strong>
            </li>
          ))}
        </ul>
        <p class="tarif-note">
          Une facture peut être remise pour un éventuel remboursement : la plupart des mutuelles
          prennent en charge une ou plusieurs séances par an.
        </p>
      </div>
    </div>
  </section>

  <section class="faq-section">
    <div class="container faq-container">
      <h2 class="h2-display reveal">Des questions&nbsp;?</h2>
      <div class="faq-list reveal">
        {faq.map((item) => (
          <details class="faq-item">
            <summary>
              {item.q}
              <span class="faq-icon" aria-hidden="true"></span>
            </summary>
            <p>{item.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>
</Base>

<style>
  .page-lead {
    text-align: center;
    max-width: 36rem;
    margin: var(--spacing-s) auto 0;
    padding-inline: clamp(1.25rem, 4vw, 2rem);
  }

  .seance-inner { max-width: 46rem; }

  .etapes-section { padding-block: var(--spacing-s) var(--spacing-m); }

  #tarifs { padding-block: var(--spacing-xl); }

  .faq-section { padding-block: var(--spacing-s) var(--spacing-xl); }

  .etapes {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .etape {
    position: relative;
    display: grid;
    grid-template-columns: 3.25rem 1fr;
    gap: 1.25rem;
    padding-bottom: 2.5rem;
  }

  .etape:last-child { padding-bottom: 0; }

  .etape:not(:last-child)::before {
    content: '';
    position: absolute;
    left: 1.625rem;
    top: 3.5rem;
    bottom: 0.25rem;
    width: 1px;
    background: var(--color-light-border);
  }

  .etape-num {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 3.25rem;
    height: 3.25rem;
    border-radius: 50%;
    background: var(--color-opaque);
    border: 1px solid var(--color-light-border);
    color: var(--color-text-primary);
  }

  .etape-num svg {
    width: 100%;
    height: 100%;
  }

  .etape-num text {
    font-family: var(--titleFont);
    font-weight: 700;
    font-size: 43px;
    fill: currentColor;
  }

  .etape h3 {
    margin-bottom: 0.4rem;
    padding-top: 0.55rem;
  }

  .etape p { margin-bottom: 0; }

  .tarif-card {
    margin-top: var(--spacing-m);
    padding: clamp(1.75rem, 4vw, 2.75rem);
    background: var(--color-opaque);
    border: 1px solid var(--color-light-border);
    border-radius: var(--radius-card);
  }

  .tarif-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .tarif-list li {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    padding: 0.9rem 0;
    border-bottom: 1px solid var(--color-light-border);
    font-size: var(--font-body);
    color: var(--color-text-secondary);
  }

  .tarif-list li:first-child { padding-top: 0; }

  .tarif-list li:last-child { border-bottom: none; padding-bottom: 0; }

  .tarif-prix {
    font-family: var(--titleFont);
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--color-text-primary);
  }

  .tarif-note {
    font-size: var(--font-mini);
    margin: 1.25rem 0 0;
    padding-top: 1.25rem;
    border-top: 1px solid var(--color-light-border);
  }

  .faq-container {
    max-width: 46rem;
    padding-inline: clamp(1.5rem, 5vw, 2.25rem);
  }

  .faq-list {
    border-top: 1px solid var(--color-light-border);
    margin-top: var(--spacing-m);
  }

  .faq-item {
    border-bottom: 1px solid var(--color-light-border);
  }

  .faq-item summary {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    list-style: none;
    cursor: pointer;
    padding: 1.15rem 0;
    font-family: var(--titleFont);
    font-size: var(--font-body);
    font-weight: 600;
    color: var(--color-text-primary);
    transition: color 0.2s ease-in-out;
  }

  .faq-item summary::-webkit-details-marker { display: none; }

  .faq-item summary:hover { color: var(--color-text-secondary); }

  .faq-icon {
    position: relative;
    flex: none;
    width: 0.9rem;
    height: 0.9rem;
  }

  .faq-icon::before,
  .faq-icon::after {
    content: '';
    position: absolute;
    inset: 50% auto auto 0;
    width: 100%;
    height: 2px;
    border-radius: 2px;
    background: var(--color-text-primary);
    transition: rotate 0.3s var(--ease-out);
  }

  .faq-icon::after { rotate: 90deg; }

  .faq-item[open] .faq-icon::after { rotate: 0deg; }

  .faq-item[open] .faq-icon::before { rotate: 180deg; }

  .faq-item p {
    margin: 0 0 1.25rem;
    max-width: 40rem;
  }
</style>
